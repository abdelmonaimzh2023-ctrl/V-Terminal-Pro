<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#FF000000"
    android:padding="2dp">

    <!-- Extra Keys Row (مثل Termux) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="0dp">

        <Button android:text="ESC" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:textSize="10sp" android:textColor="#FFFFFFFF" android:background="#FF1A1A1A" />
        <Button android:text="TAB" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:textSize="10sp" android:textColor="#FFFFFFFF" android:background="#FF1A1A1A" />
        <Button android:text="CTRL" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:textSize="10sp" android:textColor="#FFFFFFFF" android:background="#FF1A1A1A" />
        <Button android:text="ALT" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:textSize="10sp" android:textColor="#FFFFFFFF" android:background="#FF1A1A1A" />
        <Button android:text="-" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:textSize="12sp" android:textColor="#FFFFFFFF" android:background="#FF1A1A1A" />
        <Button android:text="/" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:textSize="12sp" android:textColor="#FFFFFFFF" android:background="#FF1A1A1A" />
        <Button android:text="|" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:textSize="12sp" android:textColor="#FFFFFFFF" android:background="#FF1A1A1A" />
        <Button android:text="UP" android:layout_width="0dp" android:layout_height="40dp" android:layout_weight="1" android:textSize="10sp" android:textColor="#FFFFFFFF" android:background="#FF1A1A1A" />
    </LinearLayout>

    <!-- Progress Bar (يظهر عند فك الضغط) -->
    <LinearLayout
        android:id="@+id/progressLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="4dp"
        android:visibility="gone"
        android:background="#FF1A1A1A">

        <ProgressBar
            android:id="@+id/progressBar"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="0dp"
            android:layout_height="8dp"
            android:layout_weight="1" />

        <TextView
            android:id="@+id/progressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FF00FF00"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:paddingStart="4dp"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/cancelBtn"
            android:layout_width="30dp"
            android:layout_height="24dp"
            android:text="X"
            android:textColor="#FFFF0000"
            android:background="@android:color/transparent"
            android:textSize="10sp" />
    </LinearLayout>

    <!-- Terminal Output (مثل Termux) -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:scrollbarStyle="insideOverlay">

        <TextView
            android:id="@+id/terminalOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FF00FF00"
            android:textSize="12sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="6dp"
            android:background="#FF000000"
            android:typeface="monospace" />
    </ScrollView>

    <!-- Input Bar (مثل Termux) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#FF0D0D0D"
        android:padding="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="$ "
            android:textColor="#FF00FF00"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingStart="4dp"
            android:paddingEnd="2dp" />

        <EditText
            android:id="@+id/terminalInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FF00FF00"
            android:textColorHint="#FF003300"
            android:background="@android:color/transparent"
            android:hint="command..."
            android:inputType="text"
            android:imeOptions="actionSend"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingStart="2dp"
            android:paddingEnd="4dp" />

        <Button
            android:id="@+id/sendBtn"
            android:layout_width="36dp"
            android:layout_height="32dp"
            android:text=">"
            android:textColor="#FF000000"
            android:backgroundTint="#FF00FF00"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- Bottom Bar: Browse + Settings -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FF0D0D0D"
        android:padding="2dp">

        <Button
            android:id="@+id/browseBtn"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="BROWSE"
            android:textColor="#FF00FF00"
            android:background="#FF1A1A1A"
            android:textSize="10sp" />

        <Button
            android:id="@+id/settingsBtn"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="SETTINGS"
            android:textColor="#FF00FF00"
            android:background="#FF1A1A1A"
            android:textSize="10sp" />
    </LinearLayout>
</LinearLayout>
