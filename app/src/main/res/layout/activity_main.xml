<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/animated_bg"
    android:padding="10dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="V-Terminal Pro"
        android:textColor="#FF00FFCC"
        android:textSize="16sp"
        android:fontFamily="monospace"
        android:layout_marginBottom="4dp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="vertical"
        android:scrollbarStyle="insideOverlay">

        <TextView
            android:id="@+id/terminalOutput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFE0F7FA"
            android:textSize="13sp"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"
            android:padding="8dp"
            android:background="#CC0D0E15" />
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="@drawable/input_bar_glass"
        android:padding="10dp"
        android:layout_marginTop="6dp"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="root@ubuntu:~#"
            android:textColor="#FFFF0055"
            android:textSize="14sp"
            android:fontFamily="monospace" />

        <EditText
            android:id="@+id/terminalInput"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textColor="#FFFFFFFF"
            android:textColorHint="#FF555555"
            android:background="@android:color/transparent"
            android:hint="enter command..."
            android:inputType="text"
            android:imeOptions="actionSend"
            android:textSize="14sp"
            android:fontFamily="monospace"
            android:paddingStart="8dp"
            android:paddingEnd="8dp" />

        <Button
            android:id="@+id/sendBtn"
            android:layout_width="46dp"
            android:layout_height="40dp"
            android:text="▶"
            android:textColor="#FF000000"
            android:backgroundTint="#FF00FFCC"
            android:textSize="16sp" />
    </LinearLayout>
</LinearLayout>
